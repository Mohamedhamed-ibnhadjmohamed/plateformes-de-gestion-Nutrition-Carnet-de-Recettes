@using SmartNutrition.Models

<EditForm Model="@Unite" OnValidSubmit="OnValidSubmit">
    <DataAnnotationsValidator />
    
    <div class="mb-3">
        <label class="form-label">Libellé *</label>
        <InputText class="form-control" @bind-Value="Unite.Libelle" 
                   placeholder="ex: Gramme, Kilogramme, Millilitre" />
        <ValidationMessage For="@(() => Unite.Libelle)" class="text-danger" />
        <small class="form-text text-muted">Nom complet de l'unité de mesure</small>
    </div>

    <div class="mb-3">
        <label class="form-label">Symbole *</label>
        <InputText class="form-control" @bind-Value="Unite.Symbole" 
                   placeholder="ex: g, kg, ml, pcs" />
        <ValidationMessage For="@(() => Unite.Symbole)" class="text-danger" />
        <small class="form-text text-muted">Abréviation utilisée dans les recettes</small>
    </div>

    @if (ShowId)
    {
        <div class="mb-3">
            <label class="form-label">ID</label>
            <InputNumber class="form-control" @bind-Value="Unite.Id" readonly="true" />
            <small class="form-text text-muted">Identifiant unique de l'unité</small>
        </div>
    }

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary" disabled="@IsSubmitting">
            @if (IsSubmitting)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            }
            @SubmitButtonText
        </button>
        @if (ShowCancel)
        {
            <button type="button" class="btn btn-secondary" @onclick="OnCancelClicked">
                Annuler
            </button>
        }
    </div>
</EditForm>

@code {
    [Parameter]
    public Unite Unite { get; set; } = new();

    [Parameter]
    public EventCallback OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancelClicked { get; set; }

    [Parameter]
    public string SubmitButtonText { get; set; } = "Enregistrer";

    [Parameter]
    public bool IsSubmitting { get; set; }

    [Parameter]
    public bool ShowCancel { get; set; } = true;

    [Parameter]
    public bool ShowId { get; set; } = false;
}
