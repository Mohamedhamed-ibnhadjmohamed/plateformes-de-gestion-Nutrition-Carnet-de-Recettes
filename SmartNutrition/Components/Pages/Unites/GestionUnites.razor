@page "/gestion-unites"
@using SmartNutrition.Models
@using SmartNutrition.Services
@using SmartNutrition.Components.UI
@inject IUniteService UniteService
@inject NavigationManager NavigationManager

<PageTitle>Gestion des Unités</PageTitle>

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col">
            <h2><i class="bi bi-rulers me-2"></i>Gestion des Unités</h2>
            <p class="text-muted">Gérez les unités de mesure</p>
        </div>
        <div class="col-auto">
            <AuthorizeView Roles="Admin">
                <NavLink href="/gestion-unites/ajouter" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-2"></i>Ajouter
                </NavLink>
            </AuthorizeView>
        </div>
    </div>

    <!-- Recherche -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control" placeholder="Rechercher..." 
                               @bind="searchTerm" @onkeyup="OnSearch" />
                        <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch">
                            <i class="bi bi-x-circle"></i>
                        </button>
                    </div>
                </div>
                <div class="col-md-4">
                    <button class="btn btn-outline-secondary w-100" @onclick="RefreshData">
                        <i class="bi bi-arrow-clockwise me-2"></i>Actualiser
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Liste des unités -->
    <div class="card">
        <div class="card-body">
            @if (loading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary"></div>
                    <p class="mt-2">Chargement...</p>
                </div>
            }
            else if (unites?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Nom</th>
                                <th>Symbole</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var unite in unites)
                            {
                                <tr>
                                    <td class="fw-bold">@unite.Libelle</td>
                                    <td>
                                        <span class="badge bg-info fs-6">@unite.Symbole</span>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <NavLink href="@($"/detail-unite/{unite.Id}")" 
                                                   class="btn btn-outline-info">
                                                <i class="bi bi-eye"></i>
                                            </NavLink>
                                            <AuthorizeView Roles="Admin">
                                                <NavLink href="@($"/modifier-unite/{unite.Id}")" 
                                                       class="btn btn-outline-warning">
                                                    <i class="bi bi-pencil"></i>
                                                </NavLink>
                                                <button class="btn btn-outline-danger" 
                                                       @onclick="() => ShowDeleteModal(unite)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </AuthorizeView>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox fs-1 text-muted mb-3"></i>
                    <p class="text-muted">Aucune unité trouvée</p>
                    <AuthorizeView Roles="Admin">
                        <NavLink href="/gestion-unites/ajouter" class="btn btn-primary">
                            <i class="bi bi-plus-circle me-2"></i>Ajouter la première unité
                        </NavLink>
                    </AuthorizeView>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal de suppression -->
<ConfirmationModal 
    Show="@showDeleteModal" 
    Title="Supprimer une unité"
    Message="Êtes-vous sûr de vouloir supprimer cette unité ?"
    OnConfirm="ConfirmDelete"
    OnCancel="HideDeleteModal" />

@code {
    private List<Unite>? unites;
    private Unite? deletingUnite;
    private bool loading = true;
    private bool showDeleteModal = false;
    private string searchTerm = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadUnites();
    }

    private async Task LoadUnites()
    {
        loading = true;
        try
        {
            unites = (await UniteService.GetAllUnitesAsync()).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task OnSearch()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            await LoadUnites();
        }
        else
        {
            unites = (await UniteService.SearchUnitesAsync(searchTerm)).ToList();
        }
    }

    private void ClearSearch()
    {
        searchTerm = "";
        _ = Task.Run(LoadUnites);
    }

    private async Task RefreshData()
    {
        searchTerm = "";
        await LoadUnites();
    }

    private void ShowDeleteModal(Unite unite)
    {
        deletingUnite = unite;
        showDeleteModal = true;
    }

    private void HideDeleteModal()
    {
        showDeleteModal = false;
        deletingUnite = null;
    }

    private async Task ConfirmDelete()
    {
        if (deletingUnite == null) return;

        try
        {
            await UniteService.DeleteUniteAsync(deletingUnite.Id);
            HideDeleteModal();
            await LoadUnites();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }
}
