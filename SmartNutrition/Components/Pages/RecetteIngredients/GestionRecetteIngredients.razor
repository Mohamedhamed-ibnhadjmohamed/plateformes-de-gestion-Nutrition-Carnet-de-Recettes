@page "/gestion-recette-ingredients"
@using SmartNutrition.Models
@using SmartNutrition.Services
@inject IRecetteService RecetteService
@inject NavigationManager NavigationManager

<PageTitle>Gestion des Ingrédients de Recettes</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h2>Gestion des Ingrédients de Recettes</h2>
            <p class="text-muted">Gérez les ingrédients associés aux recettes</p>
        </div>
        <div class="col-auto">
            <button class="btn btn-primary" @onclick="NavigateToAdd">
                <i class="bi bi-plus-circle"></i> Ajouter un ingrédient à une recette
            </button>
        </div>
    </div>

    <!-- Filtres -->
    <div class="row mb-4">
        <div class="col-md-4">
            <label class="form-label">Rechercher</label>
            <input class="form-control" @bind="searchTerm" placeholder="Rechercher un ingrédient ou une recette..." />
        </div>
        <div class="col-md-3">
            <label class="form-label">Filtrer par recette</label>
            <select class="form-select" @bind="selectedRecetteId">
                <option value="">Toutes les recettes</option>
                @if (recettes != null)
                {
                    @foreach (var recette in recettes)
                    {
                        <option value="@recette.Id">@recette.Nom</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Filtrer par ingrédient</label>
            <select class="form-select" @bind="selectedIngredientId">
                <option value="">Tous les ingrédients</option>
                @if (ingredients != null)
                {
                    @foreach (var ingredient in ingredients)
                    {
                        <option value="@ingredient.Id">@ingredient.Nom</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">&nbsp;</label><br />
            <button class="btn btn-outline-secondary w-100" @onclick="ApplyFilters">
                <i class="bi bi-funnel"></i> Filtrer
            </button>
        </div>
    </div>

    <!-- Tableau des ingrédients de recettes -->
    @if (loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Chargement...</span>
            </div>
        </div>
    }
    else if (!filteredRecetteIngredients.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Aucun ingrédient de recette trouvé.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Recette</th>
                        <th>Ingrédient</th>
                        <th>Quantité</th>
                        <th>Unité</th>
                        <th>Affichage</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ri in filteredRecetteIngredients)
                    {
                        <tr>
                            <td>
                                <strong>@ri.Recette?.Nom</strong>
                                @if (ri.Recette?.TypeCuisine != null)
                                {
                                    <br />
                                    <small class="text-muted">@ri.Recette.TypeCuisine.Libelle</small>
                                }
                            </td>
                            <td>
                                <strong>@ri.Ingredient?.Nom</strong>
                                @if (ri.Ingredient?.Unite != null)
                                {
                                    <br />
                                    <small class="text-muted">Unité: @ri.Ingredient.Unite.Libelle</small>
                                }
                            </td>
                            <td>@ri.Quantite</td>
                            <td>@ri.Unite?.Symbole</td>
                            <td>
                                <span class="badge bg-light text-dark">
                                    @ri.Affichage
                                </span>
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => NavigateToEdit(ri.Id)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <NavLink href="@($"/detail-recette-ingredient/{ri.Id}")" 
                                             class="btn btn-sm btn-outline-info"
                                             title="Voir détail">
                                        <i class="bi bi-eye"></i>
                                    </NavLink>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => ShowDeleteModal(ri)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Modal de confirmation de suppression -->
@if (showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmation de suppression</h5>
                    <button type="button" class="btn-close" @onclick="HideDeleteModal"></button>
                </div>
                <div class="modal-body">
                    <p>Êtes-vous sûr de vouloir supprimer cet ingrédient de la recette ?</p>
                    @if (itemToDelete != null)
                    {
                        <div class="alert alert-warning">
                            <strong>@itemToDelete.Quantite @itemToDelete.Unite?.Symbole @itemToDelete.Ingredient?.Nom</strong>
                            <br />
                            <small>Dans la recette : @itemToDelete.Recette?.Nom</small>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="HideDeleteModal">Annuler</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">Supprimer</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<RecetteIngredient> recetteIngredients = new List<RecetteIngredient>();
    private List<RecetteIngredient> filteredRecetteIngredients = new List<RecetteIngredient>();
    private List<Recette>? recettes;
    private List<Ingredient>? ingredients;
    private List<Unite>? unites;
    private bool loading = true;
    private string searchTerm = "";
    private int selectedRecetteId = 0;
    private int selectedIngredientId = 0;

    // Modal suppression
    private bool showDeleteModal = false;
    private RecetteIngredient? itemToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        try
        {
            recetteIngredients = await RecetteService.GetRecetteIngredientsAsync();
            recettes = (await RecetteService.GetRecettesAsync()).ToList();
            ingredients = (await RecetteService.GetIngredientsAsync()).ToList();
            unites = (await RecetteService.GetUnitesAsync()).ToList();
            
            ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    private void ApplyFilters()
    {
        filteredRecetteIngredients = recetteIngredients.ToList();

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredRecetteIngredients = filteredRecetteIngredients
                .Where(ri => (ri.Recette?.Nom?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                           (ri.Ingredient?.Nom?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
                .ToList();
        }

        if (selectedRecetteId > 0)
        {
            filteredRecetteIngredients = filteredRecetteIngredients
                .Where(ri => ri.RecetteId == selectedRecetteId)
                .ToList();
        }

        if (selectedIngredientId > 0)
        {
            filteredRecetteIngredients = filteredRecetteIngredients
                .Where(ri => ri.IngredientId == selectedIngredientId)
                .ToList();
        }

    }

    private void NavigateToAdd()
    {
        NavigationManager.NavigateTo("/ajouter-recette-ingredient");
    }

    private void NavigateToEdit(int id)
    {
        NavigationManager.NavigateTo($"/modifier-recette-ingredient/{id}");
    }

    private void ShowDeleteModal(RecetteIngredient recetteIngredient)
    {
        itemToDelete = recetteIngredient;
        showDeleteModal = true;
    }

    private void HideDeleteModal()
    {
        showDeleteModal = false;
        itemToDelete = null;
    }

    private async Task ConfirmDelete()
    {
        if (itemToDelete != null)
        {
            try
            {
                await RecetteService.DeleteRecetteIngredientAsync(itemToDelete.Id);
                await LoadData();
                HideDeleteModal();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting recette ingredient: {ex.Message}");
            }
        }
    }
}
