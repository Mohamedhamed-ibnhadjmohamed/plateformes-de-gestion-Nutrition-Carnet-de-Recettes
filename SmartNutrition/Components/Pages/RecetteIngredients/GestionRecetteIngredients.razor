@page "/gestion-recette-ingredients"
@using SmartNutrition.Models
@using SmartNutrition.Services
@using SmartNutrition.Components.UI
@inject IRecetteService RecetteService
@inject IIngredientService IngredientService
@inject NavigationManager NavigationManager

<PageTitle>Gestion des Associations</PageTitle>

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col">
            <h2><i class="bi bi-link-45deg me-2"></i>Gestion des Associations</h2>
            <p class="text-muted">Gérez les associations ingrédients-recettes</p>
        </div>
        <div class="col-auto">
            <AuthorizeView Roles="Admin">
                <NavLink href="/gestion-recette-ingredients/ajouter" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-2"></i>Ajouter
                </NavLink>
            </AuthorizeView>
        </div>
    </div>

    <!-- Recherche et filtres -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control" placeholder="Rechercher..." 
                               @bind="searchTerm" @onkeyup="OnSearch" />
                        <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch">
                            <i class="bi bi-x-circle"></i>
                        </button>
                    </div>
                </div>
                <div class="col-md-4">
                    <button class="btn btn-outline-secondary w-100" @onclick="RefreshData">
                        <i class="bi bi-arrow-clockwise me-2"></i>Actualiser
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Liste des associations -->
    <div class="card">
        <div class="card-body">
            @if (loading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary"></div>
                    <p class="mt-2">Chargement...</p>
                </div>
            }
            else if (recetteIngredients?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Recette</th>
                                <th>Ingrédient</th>
                                <th>Quantité</th>
                                <th>Unité</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var recetteIngredient in recetteIngredients)
                            {
                                <tr>
                                    <td class="fw-bold">
                                        @if (recetteIngredient.Recette != null)
                                        {
                                            <span>@recetteIngredient.Recette.Nom</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Recette inconnue</span>
                                        }
                                    </td>
                                    <td>
                                        @if (recetteIngredient.Ingredient != null)
                                        {
                                            <span>@recetteIngredient.Ingredient.Nom</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Ingrédient inconnu</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-primary fs-6">@recetteIngredient.Quantite</span>
                                    </td>
                                    <td>
                                        @if (recetteIngredient.Ingredient?.Unite != null)
                                        {
                                            <span class="badge bg-info">@recetteIngredient.Ingredient.Unite.Symbole</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <NavLink href="@($"/detail-recette-ingredient/{recetteIngredient.Id}")" 
                                                   class="btn btn-outline-info">
                                                <i class="bi bi-eye"></i>
                                            </NavLink>
                                            <AuthorizeView Roles="Admin">
                                                <NavLink href="@($"/modifier-recette-ingredient/{recetteIngredient.Id}")" 
                                                       class="btn btn-outline-warning">
                                                    <i class="bi bi-pencil"></i>
                                                </NavLink>
                                                <button class="btn btn-outline-danger" 
                                                       @onclick="() => ShowDeleteModal(recetteIngredient)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </AuthorizeView>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox fs-1 text-muted mb-3"></i>
                    <p class="text-muted">Aucune association trouvée</p>
                    <AuthorizeView Roles="Admin">
                        <NavLink href="/gestion-recette-ingredients/ajouter" class="btn btn-primary">
                            <i class="bi bi-plus-circle me-2"></i>Ajouter la première association
                        </NavLink>
                    </AuthorizeView>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal de suppression -->
<ConfirmationModal 
    Show="@showDeleteModal" 
    Title="Supprimer une association"
    Message="Êtes-vous sûr de vouloir supprimer cette association ?"
    OnConfirm="ConfirmDelete"
    OnCancel="HideDeleteModal" />

@code {
    private List<RecetteIngredient>? recetteIngredients;
    private RecetteIngredient? deletingRecetteIngredient;
    private bool loading = true;
    private bool showDeleteModal = false;
    private string searchTerm = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadRecetteIngredients();
    }

    private async Task LoadRecetteIngredients()
    {
        loading = true;
        try
        {
            recetteIngredients = (await RecetteService.GetRecetteIngredientsAsync()).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task OnSearch()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            await LoadRecetteIngredients();
        }
        else
        {
            // Filtrage simple côté client
            var allItems = await RecetteService.GetRecetteIngredientsAsync();
            recetteIngredients = allItems.Where(ri => 
                (ri.Recette?.Nom?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (ri.Ingredient?.Nom?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
            ).ToList();
        }
    }

    private void ClearSearch()
    {
        searchTerm = "";
        _ = Task.Run(LoadRecetteIngredients);
    }

    private async Task RefreshData()
    {
        searchTerm = "";
        await LoadRecetteIngredients();
    }

    private void ShowDeleteModal(RecetteIngredient recetteIngredient)
    {
        deletingRecetteIngredient = recetteIngredient;
        showDeleteModal = true;
    }

    private void HideDeleteModal()
    {
        showDeleteModal = false;
        deletingRecetteIngredient = null;
    }

    private async Task ConfirmDelete()
    {
        if (deletingRecetteIngredient == null) return;

        try
        {
            await RecetteService.DeleteRecetteIngredientAsync(deletingRecetteIngredient.Id);
            HideDeleteModal();
            await LoadRecetteIngredients();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }
}
