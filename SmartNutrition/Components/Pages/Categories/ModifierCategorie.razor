@page "/gestion-categories/modifier/{id:int}"
@attribute [Authorize(Roles = "Admin")]
@using SmartNutrition.Models
@using SmartNutrition.Services
@inject ICategorieService CategorieService
@inject NavigationManager NavigationManager

<PageTitle>Modifier une Catégorie</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <NavLink href="/gestion-categories">Gestion des Catégories</NavLink>
                    </li>
                    <li class="breadcrumb-item active">Modifier une catégorie</li>
                </ol>
            </nav>
            <h2>Modifier la catégorie</h2>
        </div>
    </div>

    @if (loading)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Chargement...</span>
            </div>
        </div>
    }
    else if (categorie == null)
    {
        <div class="alert alert-danger">
            Catégorie non trouvée.
            <NavLink href="/gestion-categories" class="alert-link ms-2">Retour</NavLink>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <EditForm Model="@categorie" OnValidSubmit="HandleValidSubmit">
                            <DataAnnotationsValidator />
                            
                            <div class="mb-3">
                                <label class="form-label">Libellé *</label>
                                <InputText class="form-control" @bind-Value="categorie.Libelle" />
                                <ValidationMessage For="@(() => categorie.Libelle)" class="text-danger" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Icône</label>
                                <InputText class="form-control" @bind-Value="categorie.Icone" maxlength="10" />
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">Enregistrer</button>
                                <button type="button" class="btn btn-secondary" @onclick="Cancel">Annuler</button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private int id;
    private Categorie? categorie;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        var urlId = NavigationManager.Uri.Split('/').Last();
        if (int.TryParse(urlId, out int parsedId))
        {
            id = parsedId;
            categorie = await CategorieService.GetCategorieByIdAsync(id);
        }
        loading = false;
    }

    private async Task HandleValidSubmit()
    {
        if (categorie == null) return;
        await CategorieService.UpdateCategorieAsync(categorie.Id, categorie);
        NavigationManager.NavigateTo("/gestion-categories");
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/gestion-categories");
    }
}
