@page "/gestion-categories"
@using SmartNutrition.Models
@using SmartNutrition.Services
@using SmartNutrition.Components.UI
@inject ICategorieService CategorieService
@inject NavigationManager NavigationManager

<PageTitle>Gestion des Catégories</PageTitle>

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col">
            <h2><i class="bi bi-tags me-2"></i>Gestion des Catégories</h2>
            <p class="text-muted">Gérez les catégories de recettes</p>
        </div>
        <div class="col-auto">
            <NavLink href="/gestion-categories/ajouter" class="btn btn-primary">
                <i class="bi bi-plus-circle me-2"></i>Ajouter
            </NavLink>
        </div>
    </div>

    <!-- Recherche -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control" placeholder="Rechercher..." 
                               @bind="searchTerm" @onkeyup="OnSearch" />
                        <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch">
                            <i class="bi bi-x-circle"></i>
                        </button>
                    </div>
                </div>
                <div class="col-md-4">
                    <button class="btn btn-outline-secondary w-100" @onclick="RefreshData">
                        <i class="bi bi-arrow-clockwise me-2"></i>Actualiser
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Liste des catégories -->
    <div class="card">
        <div class="card-body">
            @if (loading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary"></div>
                    <p class="mt-2">Chargement...</p>
                </div>
            }
            else if (categories?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Nom</th>
                                <th>Icône</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var categorie in categories)
                            {
                                <tr>
                                    <td class="fw-bold">@categorie.Libelle</td>
                                    <td>@categorie.Icone</td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <NavLink href="@($"/detail-categorie/{categorie.Id}")" 
                                                   class="btn btn-outline-info">
                                                <i class="bi bi-eye"></i>
                                            </NavLink>
                                            <NavLink href="@($"/modifier-categorie/{categorie.Id}")" 
                                                   class="btn btn-outline-warning">
                                                <i class="bi bi-pencil"></i>
                                            </NavLink>
                                            <button class="btn btn-outline-danger" 
                                                   @onclick="() => ShowDeleteModal(categorie)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox fs-1 text-muted mb-3"></i>
                    <p class="text-muted">Aucune catégorie trouvée</p>
                    <NavLink href="/gestion-categories/ajouter" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-2"></i>Ajouter la première catégorie
                    </NavLink>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal de suppression -->
<ConfirmationModal 
    Show="@showDeleteModal" 
    Title="Supprimer une catégorie"
    Message="Êtes-vous sûr de vouloir supprimer cette catégorie ?"
    OnConfirm="ConfirmDelete"
    OnCancel="HideDeleteModal" />

@code {
    private List<Categorie>? categories;
    private Categorie? deletingCategorie;
    private bool loading = true;
    private bool showDeleteModal = false;
    private string searchTerm = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        loading = true;
        try
        {
            categories = (await CategorieService.GetAllCategoriesAsync()).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task OnSearch()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            await LoadCategories();
        }
        else
        {
            categories = (await CategorieService.SearchCategoriesAsync(searchTerm)).ToList();
        }
    }

    private void ClearSearch()
    {
        searchTerm = "";
        _ = Task.Run(LoadCategories);
    }

    private async Task RefreshData()
    {
        searchTerm = "";
        await LoadCategories();
    }

    private void ShowDeleteModal(Categorie categorie)
    {
        deletingCategorie = categorie;
        showDeleteModal = true;
    }

    private void HideDeleteModal()
    {
        showDeleteModal = false;
        deletingCategorie = null;
    }

    private async Task ConfirmDelete()
    {
        if (deletingCategorie == null) return;

        try
        {
            await CategorieService.DeleteCategorieAsync(deletingCategorie.Id);
            HideDeleteModal();
            await LoadCategories();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }
}
