@page "/detail-recette/{Id:int}"
@using SmartNutrition.Models
@using SmartNutrition.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@inject IRecetteService RecetteService
@inject NavigationManager NavigationManager

<PageTitle>Détail de la Recette</PageTitle>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-10">
            @if (loading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Chargement...</span>
                    </div>
                </div>
            }
            else if (recette == null)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle"></i> Recette non trouvée.
                </div>
            }
            else
            {
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <h4 class="mb-0">
                                <i class="bi bi-book"></i>
                                @recette.Nom
                            </h4>
                            <div>
                                <span class="badge bg-light text-dark me-2">@recette.Categorie?.Libelle</span>
                                <span class="badge bg-secondary">@recette.TypeCuisine?.Libelle</span>
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <h6>Informations générales</h6>
                                <table class="table table-sm">
                                    <tr>
                                        <th>ID:</th>
                                        <td>@recette.Id</td>
                                    </tr>
                                    <tr>
                                        <th>Nom:</th>
                                        <td><strong>@recette.Nom</strong></td>
                                    </tr>
                                    <tr>
                                        <th>Catégorie:</th>
                                        <td>
                                            <span class="badge bg-info">@recette.Categorie?.Libelle</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <th>Type de cuisine:</th>
                                        <td>
                                            <span class="badge bg-secondary">@recette.TypeCuisine?.Libelle</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <th>Nombre de personnes:</th>
                                        <td>
                                            <span class="badge bg-primary">@recette.NbPersonnes pers.</span>
                                        </td>
                                    </tr>
                                    @if (recette.DureePreparation.HasValue)
                                    {
                                        <tr>
                                            <th>Temps de préparation:</th>
                                            <td>
                                                <i class="bi bi-clock me-1"></i>@recette.DureePreparation.Value minutes
                                            </td>
                                        </tr>
                                    }
                                </table>
                            </div>
                            <div class="col-md-6">
                                <h6>Description</h6>
                                @if (!string.IsNullOrEmpty(recette.Description))
                                {
                                    <div class="alert alert-light">
                                        @recette.Description
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-warning">
                                        <i class="bi bi-info-circle"></i> Aucune description disponible.
                                    </div>
                                }
                                
                                <h6 class="mt-3">Statistiques</h6>
                                <div class="alert alert-info">
                                    <div class="row text-center">
                                        <div class="col-4">
                                            <h3 class="mb-0">@(recette.RecetteIngredients?.Count ?? 0)</h3>
                                            <small class="text-muted">Ingrédients</small>
                                        </div>
                                        <div class="col-4">
                                            <h3 class="mb-0">@recette.NbPersonnes</h3>
                                            <small class="text-muted">Personnes</small>
                                        </div>
                                        <div class="col-4">
                                            <h3 class="mb-0">@(recette.DureePreparation?.ToString() ?? "N/A")</h3>
                                            <small class="text-muted">Minutes</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (recette.RecetteIngredients?.Any() == true)
                        {
                            <div class="mt-4">
                                <h6>Ingrédients nécessaires</h6>
                                <div class="table-responsive">
                                    <table class="table table-striped table-hover">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Ingrédient</th>
                                                <th>Quantité</th>
                                                <th>Unité</th>
                                                <th>Calories</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var recetteIngredient in recette.RecetteIngredients)
                                            {
                                                <tr>
                                                    <td>
                                                        <strong>@recetteIngredient.Ingredient?.Nom</strong>
                                                    </td>
                                                    <td>@recetteIngredient.Quantite</td>
                                                    <td>
                                                        <span class="badge bg-secondary">@recetteIngredient.Unite?.Symbole</span>
                                                    </td>
                                                    <td>
                                                        @{
                                                            var calories = (recetteIngredient.Ingredient?.CaloriesParUnite ?? 0) * recetteIngredient.Quantite;
                                                        }
                                                        <span class="badge bg-warning text-dark">@calories.ToString("F0") cal</span>
                                                    </td>
                                                    <td>
                                                        <NavLink href="@($"/modifier-ingredient/{recetteIngredient.IngredientId}")" 
                                                                 class="btn btn-sm btn-outline-primary">
                                                            <i class="bi bi-pencil"></i>
                                                        </NavLink>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot class="table-light">
                                            <tr>
                                                <th>Total</th>
                                                <td colspan="2"></td>
                                                <th>
                                                    @{
                                                        var totalCalories = recette.RecetteIngredients.Sum(ri => 
                                                            (ri.Ingredient?.CaloriesParUnite ?? 0) * ri.Quantite);
                                                    }
                                                    <span class="badge bg-success text-white">@totalCalories.ToString("F0") cal</span>
                                                </th>
                                                <td></td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning mt-4">
                                <i class="bi bi-info-circle"></i> Aucun ingrédient défini pour cette recette.
                            </div>
                        }

                        @if (recette.RecetteIngredients?.Any() == true)
                        {
                            <div class="mt-4">
                                <h6>Valeurs nutritionnelles totales</h6>
                                <div class="alert alert-success">
                                    <div class="row text-center">
                                        <div class="col-3">
                                            <h4 class="mb-0">@totalCalories.ToString("F0")</h4>
                                            <small class="text-muted">Calories</small>
                                        </div>
                                        <div class="col-3">
                                            <h4 class="mb-0">@totalProteines.ToString("F1")</h4>
                                            <small class="text-muted">Protéines (g)</small>
                                        </div>
                                        <div class="col-3">
                                            <h4 class="mb-0">@totalGlucides.ToString("F1")</h4>
                                            <small class="text-muted">Glucides (g)</small>
                                        </div>
                                        <div class="col-3">
                                            <h4 class="mb-0">@totalLipides.ToString("F1")</h4>
                                            <small class="text-muted">Lipides (g)</small>
                                        </div>
                                    </div>
                                    <div class="text-center mt-2">
                                        <small class="text-muted">Valeurs par personne: @(totalCalories / recette.NbPersonnes).ToString("F0") cal</small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="card-footer">
                        <div class="d-flex justify-content-between">
                            <button type="button" class="btn btn-secondary" @onclick="@(() => NavigationManager.NavigateTo("/gestion-recettes"))">
                                <i class="bi bi-arrow-left"></i> Retour à la liste
                            </button>
                            <div>
                                <NavLink href="@($"/modifier-recette/{recette.Id}")" class="btn btn-primary me-2">
                                    <i class="bi bi-pencil"></i> Modifier la recette
                                </NavLink>
                                <NavLink href="@($"/gestion-recette-ingredients/ajouter?recetteId={recette.Id}")" class="btn btn-success">
                                    <i class="bi bi-plus-circle"></i> Ajouter un ingrédient
                                </NavLink>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private Recette? recette;
    private bool loading = true;
    private double totalCalories = 0;
    private double totalProteines = 0;
    private double totalGlucides = 0;
    private double totalLipides = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadRecette();
    }

    private async Task LoadRecette()
    {
        loading = true;
        try
        {
            var recettes = await RecetteService.GetRecettesAsync();
            recette = recettes.FirstOrDefault(r => r.Id == Id);
            
            if (recette?.RecetteIngredients != null)
            {
                totalCalories = recette.RecetteIngredients.Sum(ri => 
                    (ri.Ingredient?.CaloriesParUnite ?? 0) * ri.Quantite);
                totalProteines = recette.RecetteIngredients.Sum(ri => 
                    (ri.Ingredient?.Proteines ?? 0) * ri.Quantite);
                totalGlucides = recette.RecetteIngredients.Sum(ri => 
                    (ri.Ingredient?.Glucides ?? 0) * ri.Quantite);
                totalLipides = recette.RecetteIngredients.Sum(ri => 
                    (ri.Ingredient?.Lipides ?? 0) * ri.Quantite);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading recipe: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }
}
