@page "/gestion-recettes"
@using SmartNutrition.Models
@using SmartNutrition.Services
@using SmartNutrition.Components.UI
@inject IRecetteService RecetteService
@inject NavigationManager NavigationManager

<PageTitle>Gestion des Recettes</PageTitle>

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col">
            <h2><i class="bi bi-book me-2"></i>Gestion des Recettes</h2>
            <p class="text-muted">Gérez votre carnet de recettes</p>
        </div>
        <div class="col-auto">
            <NavLink href="/gestion-recettes/ajouter" class="btn btn-primary">
                <i class="bi bi-plus-circle me-2"></i>Ajouter
            </NavLink>
        </div>
    </div>

    <!-- Recherche et filtres -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control" placeholder="Rechercher..." 
                               @bind="searchTerm" @onkeyup="OnSearch" />
                        <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch">
                            <i class="bi bi-x-circle"></i>
                        </button>
                    </div>
                </div>
                <div class="col-md-4">
                    <button class="btn btn-outline-secondary w-100" @onclick="RefreshData">
                        <i class="bi bi-arrow-clockwise me-2"></i>Actualiser
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Liste des recettes -->
    <div class="card">
        <div class="card-body">
            @if (loading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary"></div>
                    <p class="mt-2">Chargement...</p>
                </div>
            }
            else if (recettes?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Nom</th>
                                <th>Catégorie</th>
                                <th>Type cuisine</th>
                                <th>Personnes</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var recette in recettes)
                            {
                                <tr>
                                    <td class="fw-bold">@recette.Nom</td>
                                    <td>
                                        @if (recette.Categorie != null)
                                        {
                                            <span class="badge bg-info">@recette.Categorie.Libelle</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (recette.TypeCuisine != null)
                                        {
                                            <span class="badge bg-secondary">@recette.TypeCuisine.Libelle</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-primary">@recette.NbPersonnes pers.</span>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <NavLink href="@($"/detail-recette/{recette.Id}")" 
                                                   class="btn btn-outline-info">
                                                <i class="bi bi-eye"></i>
                                            </NavLink>
                                            <NavLink href="@($"/modifier-recette/{recette.Id}")" 
                                                   class="btn btn-outline-warning">
                                                <i class="bi bi-pencil"></i>
                                            </NavLink>
                                            <button class="btn btn-outline-danger" 
                                                   @onclick="() => ShowDeleteModal(recette)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox fs-1 text-muted mb-3"></i>
                    <p class="text-muted">Aucune recette trouvée</p>
                    <NavLink href="/gestion-recettes/ajouter" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-2"></i>Ajouter la première recette
                    </NavLink>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal de suppression -->
<ConfirmationModal 
    Show="@showDeleteModal" 
    Title="Supprimer une recette"
    Message="Êtes-vous sûr de vouloir supprimer cette recette ?"
    OnConfirm="ConfirmDelete"
    OnCancel="HideDeleteModal" />

@code {
    private List<Recette>? recettes;
    private Recette? deletingRecette;
    private bool loading = true;
    private bool showDeleteModal = false;
    private string searchTerm = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadRecettes();
    }

    private async Task LoadRecettes()
    {
        loading = true;
        try
        {
            recettes = (await RecetteService.GetRecettesAsync()).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task OnSearch()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            await LoadRecettes();
        }
        else
        {
            recettes = (await RecetteService.SearchRecettesAsync(searchTerm)).ToList();
        }
    }

    private void ClearSearch()
    {
        searchTerm = "";
        _ = Task.Run(LoadRecettes);
    }

    private async Task RefreshData()
    {
        searchTerm = "";
        await LoadRecettes();
    }

    private void ShowDeleteModal(Recette recette)
    {
        deletingRecette = recette;
        showDeleteModal = true;
    }

    private void HideDeleteModal()
    {
        showDeleteModal = false;
        deletingRecette = null;
    }

    private async Task ConfirmDelete()
    {
        if (deletingRecette == null) return;

        try
        {
            await RecetteService.DeleteRecetteAsync(deletingRecette.Id);
            HideDeleteModal();
            await LoadRecettes();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }
}
