@page "/gestion-ingredients"
@using SmartNutrition.Models
@using SmartNutrition.Services
@using SmartNutrition.Components.UI
@inject IIngredientService IngredientService
@inject NavigationManager NavigationManager

<PageTitle>Gestion des Ingrédients</PageTitle>

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col">
            <h2><i class="bi bi-egg-fried me-2"></i>Gestion des Ingrédients</h2>
            <p class="text-muted">Gérez les ingrédients disponibles pour vos recettes</p>
        </div>
        <div class="col-auto">
            <NavLink href="/gestion-ingredients/ajouter" class="btn btn-primary">
                <i class="bi bi-plus-circle me-2"></i>Ajouter
            </NavLink>
        </div>
    </div>

    <!-- Recherche et filtres -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control" placeholder="Rechercher..." 
                               @bind="searchTerm" @onkeyup="OnSearch" />
                        <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch">
                            <i class="bi bi-x-circle"></i>
                        </button>
                    </div>
                </div>
                <div class="col-md-4">
                    <button class="btn btn-outline-secondary w-100" @onclick="RefreshData">
                        <i class="bi bi-arrow-clockwise me-2"></i>Actualiser
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Liste des ingrédients -->
    <div class="card">
        <div class="card-body">
            @if (loading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary"></div>
                    <p class="mt-2">Chargement...</p>
                </div>
            }
            else if (ingredients?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Nom</th>
                                <th>Calories</th>
                                <th>Unité</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ingredient in ingredients)
                            {
                                <tr>
                                    <td class="fw-bold">@ingredient.Nom</td>
                                    <td>@ingredient.CaloriesParUnite kcal</td>
                                    <td>
                                        @if (ingredient.Unite != null)
                                        {
                                            <span class="badge bg-info">@ingredient.Unite.Libelle</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <NavLink href="@($"/detail-ingredient/{ingredient.Id}")" 
                                                   class="btn btn-outline-info">
                                                <i class="bi bi-eye"></i>
                                            </NavLink>
                                            <NavLink href="@($"/modifier-ingredient/{ingredient.Id}")" 
                                                   class="btn btn-outline-warning">
                                                <i class="bi bi-pencil"></i>
                                            </NavLink>
                                            <button class="btn btn-outline-danger" 
                                                   @onclick="() => ShowDeleteModal(ingredient)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox fs-1 text-muted mb-3"></i>
                    <p class="text-muted">Aucun ingrédient trouvé</p>
                    <NavLink href="/gestion-ingredients/ajouter" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-2"></i>Ajouter le premier ingrédient
                    </NavLink>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal de suppression -->
<ConfirmationModal 
    Show="@showDeleteModal" 
    Title="Supprimer un ingrédient"
    Message="Êtes-vous sûr de vouloir supprimer cet ingrédient ?"
    OnConfirm="ConfirmDelete"
    OnCancel="HideDeleteModal" />

@code {
    private List<Ingredient>? ingredients;
    private Ingredient? deletingIngredient;
    private bool loading = true;
    private bool showDeleteModal = false;
    private string searchTerm = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadIngredients();
    }

    private async Task LoadIngredients()
    {
        loading = true;
        try
        {
            ingredients = (await IngredientService.GetAllIngredientsAsync()).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task OnSearch()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            await LoadIngredients();
        }
        else
        {
            ingredients = (await IngredientService.SearchIngredientsAsync(searchTerm)).ToList();
        }
    }

    private void ClearSearch()
    {
        searchTerm = "";
        _ = Task.Run(LoadIngredients);
    }

    private async Task RefreshData()
    {
        searchTerm = "";
        await LoadIngredients();
    }

    private void ShowDeleteModal(Ingredient ingredient)
    {
        deletingIngredient = ingredient;
        showDeleteModal = true;
    }

    private void HideDeleteModal()
    {
        showDeleteModal = false;
        deletingIngredient = null;
    }

    private async Task ConfirmDelete()
    {
        if (deletingIngredient == null) return;

        try
        {
            await IngredientService.DeleteIngredientAsync(deletingIngredient.Id);
            HideDeleteModal();
            await LoadIngredients();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }
}
