@page "/gestion-ingredients"
@using SmartNutrition.Models
@using SmartNutrition.Services
@using SmartNutrition.Components.UI
@inject IIngredientService IngredientService
@inject NavigationManager NavigationManager

<PageTitle>Gestion des Ingrédients</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h2>Gestion des Ingrédients</h2>
            <p class="text-muted">Gérez les ingrédients disponibles pour vos recettes</p>
        </div>
        <div class="col-auto">
            <NavLink href="/gestion-ingredients/ajouter" class="btn btn-primary">
                <i class="bi bi-plus-circle me-2"></i>Ajouter un ingrédient
            </NavLink>
        </div>
    </div>

    <!-- Barre de recherche -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="input-group">
                <span class="input-group-text">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" class="form-control" placeholder="Rechercher un ingrédient..." 
                       @bind="searchTerm" @bind:onchange="OnSearchChanged" />
                <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch">
                    <i class="bi bi-x-circle"></i>
                </button>
            </div>
        </div>
        <div class="col-md-3">
            <select class="form-select" @bind="selectedUniteId" @bind:onchange="OnUniteFilterChanged">
                <option value="0">Toutes les unités</option>
                @if (unites != null)
                {
                    @foreach (var unite in unites)
                    {
                        <option value="@unite.Id">@unite.Libelle (@unite.Symbole)</option>
                    }
                }
            </select>
        </div>
            </div>

    @if (loading)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Chargement...</span>
            </div>
        </div>
    }
    else if (ingredients == null || !ingredients.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            @if (!string.IsNullOrEmpty(searchTerm) || selectedUniteId > 0)
            {
                <text>Aucun ingrédient trouvé pour vos critères de recherche.</text>
                <button class="btn btn-link p-0 ms-2" @onclick="ClearFilters">
                    Effacer les filtres
                </button>
            }
            else
            {
                <text>Aucun ingrédient trouvé. Cliquez sur "Ajouter un ingrédient" pour commencer.</text>
            }
        </div>
    }
    else
    {
        <div class="mb-3">
            <small class="text-muted">
                @ingredients.Count() ingrédient@(ingredients.Count() > 1 ? "s" : "") trouvé@(ingredients.Count() > 1 ? "s" : "")
            </small>
        </div>

        <!-- Vue Liste -->
        <div class="card">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Nom</th>
                                    <th>Unité</th>
                                    <th>Calories</th>
                                    <th>Recettes</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ingredient in ingredients)
                                {
                                    <tr>
                                        <td><strong>@ingredient.Nom</strong></td>
                                        <td>
                                            <span class="badge bg-secondary">@ingredient.Unite?.Symbole</span>
                                        </td>
                                        <td>@ingredient.CaloriesParUnite cal/@ingredient.Unite?.Symbole</td>
                                        <td>
                                            <span class="badge bg-info">@ingredient.RecetteIngredients.Count</span>
                                        </td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <NavLink href="@($"/gestion-ingredients/modifier/{ingredient.Id}")" 
                                                         class="btn btn-sm btn-outline-primary"
                                                         title="Modifier">
                                                    <i class="bi bi-pencil"></i>
                                                </NavLink>
                                                <NavLink href="@($"/detail-ingredient/{ingredient.Id}")" 
                                                         class="btn btn-sm btn-outline-info"
                                                         title="Voir détail">
                                                    <i class="bi bi-eye"></i>
                                                </NavLink>
                                                <button class="btn btn-sm btn-outline-danger" 
                                                        @onclick="() => ShowDeleteModal(ingredient)"
                                                        title="Supprimer"
                                                        disabled="@(ingredient.RecetteIngredients.Count > 0)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    
</div>

<ConfirmationModal Show="showDeleteModal"
                   Title="Supprimer un ingrédient"
                   Message="@(deletingIngredient != null ? $"Êtes-vous sûr de vouloir supprimer l'ingrédient {deletingIngredient.Nom} ?" : "Êtes-vous sûr de vouloir supprimer cet ingrédient ?")"
                   WarningMessage="@(deletingIngredient?.RecetteIngredients.Count > 0 ? $"Attention : {deletingIngredient.RecetteIngredients.Count} recette(s) utilisent cet ingrédient. Vous devez d'abord modifier ou supprimer ces recettes." : null)"
                   ConfirmText="Supprimer"
                   CancelText="Annuler"
                   ConfirmButtonClass="btn-danger"
                   ConfirmDisabled="@(deletingIngredient?.RecetteIngredients.Count > 0)"
                   OnConfirm="ConfirmDelete"
                   OnCancel="HideDeleteModal" />

@code {
    private List<Ingredient>? ingredients;
    private List<Unite>? unites;
    private Ingredient? deletingIngredient;
    private bool loading = true;
    private bool showDeleteModal = false;
    private string searchTerm = "";
    private int selectedUniteId = 0;
    
    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        try
        {
            await Task.WhenAll(LoadIngredients(), LoadUnites());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task LoadIngredients()
    {
        if (!string.IsNullOrEmpty(searchTerm))
        {
            ingredients = (await IngredientService.SearchIngredientsAsync(searchTerm)).ToList();
        }
        else if (selectedUniteId > 0)
        {
            ingredients = (await IngredientService.GetIngredientsByUniteIdAsync(selectedUniteId)).ToList();
        }
        else
        {
            ingredients = (await IngredientService.GetAllIngredientsAsync()).ToList();
        }
    }

    private async Task LoadUnites()
    {
        try
        {
            // Charger les unités pour le filtre - pour l'instant, liste vide
            unites = new List<Unite>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading unites: {ex.Message}");
        }
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        await LoadIngredients();
    }

    private async Task OnUniteFilterChanged(ChangeEventArgs e)
    {
        selectedUniteId = int.Parse(e.Value?.ToString() ?? "0");
        await LoadIngredients();
    }

    private void ClearSearch()
    {
        searchTerm = "";
        _ = Task.Run(LoadIngredients);
    }

    private void ClearFilters()
    {
        searchTerm = "";
        selectedUniteId = 0;
        _ = Task.Run(LoadIngredients);
    }

    private void ShowDeleteModal(Ingredient ingredient)
    {
        deletingIngredient = ingredient;
        showDeleteModal = true;
    }

    private void HideDeleteModal()
    {
        showDeleteModal = false;
        deletingIngredient = null;
    }

    private async Task ConfirmDelete()
    {
        if (deletingIngredient == null) return;

        try
        {
            await IngredientService.DeleteIngredientAsync(deletingIngredient.Id);
            HideDeleteModal();
            await LoadIngredients();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting ingredient: {ex.Message}");
        }
    }
}
