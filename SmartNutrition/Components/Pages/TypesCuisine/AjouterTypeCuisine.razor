@page "/gestion-types-cuisine/ajouter"
@attribute [Authorize(Roles = "Admin")]
@using SmartNutrition.Models
@using SmartNutrition.Services
@inject ITypeCuisineService TypeCuisineService
@inject NavigationManager NavigationManager

<PageTitle>Ajouter un Type de Cuisine</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <NavLink href="/gestion-types-cuisine">Gestion des Types de Cuisine</NavLink>
                    </li>
                    <li class="breadcrumb-item active">Ajouter un type de cuisine</li>
                </ol>
            </nav>
            <h2>Ajouter un type de cuisine</h2>
            <p class="text-muted">Créez un nouveau type de cuisine pour classer vos recettes</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <EditForm Model="@nouveauTypeCuisine" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />
                        
                        <div class="mb-3">
                            <label class="form-label">Libellé *</label>
                            <InputText class="form-control" @bind-Value="nouveauTypeCuisine.Libelle" 
                                       placeholder="ex: Tunisienne, Française, Italienne" />
                            <ValidationMessage For="@(() => nouveauTypeCuisine.Libelle)" class="text-danger" />
                            <small class="form-text text-muted">Nom du type de cuisine</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Pays d'origine</label>
                            <InputText class="form-control" @bind-Value="nouveauTypeCuisine.Pays" 
                                       placeholder="ex: Tunisie, France, Italie" />
                            <ValidationMessage For="@(() => nouveauTypeCuisine.Pays)" class="text-danger" />
                            <small class="form-text text-muted">Pays d'origine (optionnel)</small>
                        </div>

                        <div class="alert alert-light">
                            <h6 class="alert-heading">
                                <i class="bi bi-lightbulb me-2"></i>Suggestions de types de cuisine
                            </h6>
                            <div class="row">
                                <div class="col-md-6">
                                    <small class="d-block mb-1">
                                        <strong>Cuisine méditerranéenne:</strong><br>
                                        • Tunisienne 🇹🇳<br>
                                        • Algérienne 🇩🇿<br>
                                        • Marocaine 🇲🇦<br>
                                        • Française 🇫🇷<br>
                                        • Italienne 🇮🇹<br>
                                        • Espagnole 🇪🇸
                                    </small>
                                </div>
                                <div class="col-md-6">
                                    <small class="d-block">
                                        <strong>Cuisine asiatique:</strong><br>
                                        • Chinoise 🇨🇳<br>
                                        • Japonaise 🇯🇵<br>
                                        • Thaïlandaise 🇹🇭<br>
                                        • Indienne 🇮🇳<br>
                                        • Vietnamienne 🇻🇳<br>
                                        • Coréenne 🇰🇷
                                    </small>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                }
                                Ajouter le type de cuisine
                            </button>
                            <button type="button" class="btn btn-secondary" @onclick="Cancel">
                                Annuler
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Conseils</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <i class="bi bi-info-circle text-primary me-2"></i>
                            <strong>Libellé:</strong> Utilisez un nom descriptif et unique
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-info-circle text-primary me-2"></i>
                            <strong>Pays:</strong> Précisez le pays d'origine pour mieux classer
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-info-circle text-primary me-2"></i>
                            <strong>Exemples:</strong> "Tunisienne" avec "Tunisie", "Française" avec "France"
                        </li>
                    </ul>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header">
                    <h5 class="card-title mb-0">Types de cuisine existants</h5>
                </div>
                <div class="card-body">
                    @if (typesCuisineExistants == null || !typesCuisineExistants.Any())
                    {
                        <p class="text-muted">Aucun type de cuisine existant</p>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var typeCuisine in typesCuisineExistants.Take(5))
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@typeCuisine.Libelle</strong>
                                        @if (!string.IsNullOrEmpty(typeCuisine.Pays))
                                        {
                                            <br>
                                            <small class="text-muted">
                                                <i class="bi bi-geo-alt me-1"></i>@typeCuisine.Pays
                                            </small>
                                        }
                                    </div>
                                    <span class="badge bg-info">
                                        @(typeCuisine.Recettes?.Count ?? 0)
                                    </span>
                                </div>
                            }
                        </div>
                        @if (typesCuisineExistants.Count > 5)
                        {
                            <small class="text-muted d-block mt-2">
                                Et @typesCuisineExistants.Count - 5 autres types...
                            </small>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private TypeCuisine nouveauTypeCuisine = new();
    private List<TypeCuisine>? typesCuisineExistants;
    private bool isSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadTypesCuisineExistants();
    }

    private async Task LoadTypesCuisineExistants()
    {
        try
        {
            typesCuisineExistants = (await TypeCuisineService.GetAllTypesCuisineAsync()).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading existing types cuisine: {ex.Message}");
        }
    }

    private async Task HandleValidSubmit()
    {
        if (nouveauTypeCuisine == null) return;

        isSubmitting = true;
        try
        {
            await TypeCuisineService.CreateTypeCuisineAsync(nouveauTypeCuisine);
            
            // Rediriger vers la page de gestion
            NavigationManager.NavigateTo("/gestion-types-cuisine");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating type cuisine: {ex.Message}");
            // TODO: Afficher un message d'erreur à l'utilisateur
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/gestion-types-cuisine");
    }
}
