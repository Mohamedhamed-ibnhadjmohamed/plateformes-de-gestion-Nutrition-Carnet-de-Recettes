@page "/gestion-types-cuisine"
@using SmartNutrition.Models
@using SmartNutrition.Services
@using SmartNutrition.Components.UI
@inject ITypeCuisineService TypeCuisineService
@inject NavigationManager NavigationManager

<PageTitle>Gestion des Types de Cuisine</PageTitle>

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col">
            <h2><i class="bi bi-globe me-2"></i>Gestion des Types de Cuisine</h2>
            <p class="text-muted">Gérez les types de cuisine</p>
        </div>
        <div class="col-auto">
            <AuthorizeView Roles="Admin">
                <NavLink href="/gestion-types-cuisine/ajouter" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-2"></i>Ajouter
                </NavLink>
            </AuthorizeView>
        </div>
    </div>

    <!-- Recherche -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control" placeholder="Rechercher..." 
                               @bind="searchTerm" @onkeyup="OnSearch" />
                        <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch">
                            <i class="bi bi-x-circle"></i>
                        </button>
                    </div>
                </div>
                <div class="col-md-4">
                    <button class="btn btn-outline-secondary w-100" @onclick="RefreshData">
                        <i class="bi bi-arrow-clockwise me-2"></i>Actualiser
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Liste des types de cuisine -->
    <div class="card">
        <div class="card-body">
            @if (loading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary"></div>
                    <p class="mt-2">Chargement...</p>
                </div>
            }
            else if (typesCuisine?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Nom</th>
                                <th>Pays d'origine</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var typeCuisine in typesCuisine)
                            {
                                <tr>
                                    <td class="fw-bold">@typeCuisine.Libelle</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(typeCuisine.Pays))
                                        {
                                            <span class="badge bg-info">@typeCuisine.Pays</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <NavLink href="@($"/detail-type-cuisine/{typeCuisine.Id}")" 
                                                   class="btn btn-outline-info">
                                                <i class="bi bi-eye"></i>
                                            </NavLink>
                                            <AuthorizeView Roles="Admin">
                                                <NavLink href="@($"/modifier-type-cuisine/{typeCuisine.Id}")" 
                                                       class="btn btn-outline-warning">
                                                    <i class="bi bi-pencil"></i>
                                                </NavLink>
                                                <button class="btn btn-outline-danger" 
                                                       @onclick="() => ShowDeleteModal(typeCuisine)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </AuthorizeView>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox fs-1 text-muted mb-3"></i>
                    <p class="text-muted">Aucun type de cuisine trouvé</p>
                    <AuthorizeView Roles="Admin">
                        <NavLink href="/gestion-types-cuisine/ajouter" class="btn btn-primary">
                            <i class="bi bi-plus-circle me-2"></i>Ajouter le premier type de cuisine
                        </NavLink>
                    </AuthorizeView>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal de suppression -->
<ConfirmationModal 
    Show="@showDeleteModal" 
    Title="Supprimer un type de cuisine"
    Message="Êtes-vous sûr de vouloir supprimer ce type de cuisine ?"
    OnConfirm="ConfirmDelete"
    OnCancel="HideDeleteModal" />

@code {
    private List<TypeCuisine>? typesCuisine;
    private TypeCuisine? deletingTypeCuisine;
    private bool loading = true;
    private bool showDeleteModal = false;
    private string searchTerm = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadTypesCuisine();
    }

    private async Task LoadTypesCuisine()
    {
        loading = true;
        try
        {
            typesCuisine = (await TypeCuisineService.GetAllTypesCuisineAsync()).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task OnSearch()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            await LoadTypesCuisine();
        }
        else
        {
            typesCuisine = (await TypeCuisineService.SearchTypesCuisineAsync(searchTerm)).ToList();
        }
    }

    private void ClearSearch()
    {
        searchTerm = "";
        _ = Task.Run(LoadTypesCuisine);
    }

    private async Task RefreshData()
    {
        searchTerm = "";
        await LoadTypesCuisine();
    }

    private void ShowDeleteModal(TypeCuisine typeCuisine)
    {
        deletingTypeCuisine = typeCuisine;
        showDeleteModal = true;
    }

    private void HideDeleteModal()
    {
        showDeleteModal = false;
        deletingTypeCuisine = null;
    }

    private async Task ConfirmDelete()
    {
        if (deletingTypeCuisine == null) return;

        try
        {
            await TypeCuisineService.DeleteTypeCuisineAsync(deletingTypeCuisine.Id);
            HideDeleteModal();
            await LoadTypesCuisine();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }
}
